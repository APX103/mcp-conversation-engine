{
  "llm": {
    "baseUrl": "https://api.deepseek.com",
    "apiKey": "YOUR_DEEPSEEK_API_KEY",
    "model": "deepseek-v4-pro",
    "thinking": true,
    "reasoningEffort": "high"
  },
  "mongodb": {
    "uri": "mongodb://localhost:27017",
    "dbName": "mcp-conversation-engine"
  },
  "mcpServers": {
    "web-search-prime": {
      "transport": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer YOUR_API_KEY"
      }
    },
    "calculator": {
      "command": "node",
      "args": ["./example-mcp-server/index.js"],
      "transport": "stdio"
    }
  },
  "server": {
    "port": 3000
  },
  "scheduler": {
    "enabled": true,
    "timezone": "Asia/Shanghai",
    "tasks": {
      "nightlyConsolidate": {
        "enabled": true,
        "cron": "0 3 * * *"
      },
      "cleanupOldLogs": {
        "enabled": true,
        "cron": "0 4 * * *",
        "retentionDays": 30
      },
      "cleanupOldCommitments": {
        "enabled": true,
        "cron": "30 4 * * *",
        "retentionDays": 30
      }
    }
  }
}
