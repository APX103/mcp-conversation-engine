{
  "llm": {
    "baseUrl": "https://api.deepseek.com",
    "apiKey": "YOUR_DEEPSEEK_API_KEY",
    "model": "deepseek-v4-pro",
    "thinking": true,
    "reasoningEffort": "high"
  },
  "mongodb": {
    "uri": "mongodb://localhost:27017",
    "dbName": "mcp-conversation-engine"
  },
  "mcpServers": {
    "web-search-prime": {
      "transport": "http",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "Bearer YOUR_API_KEY"
      }
    },
    "calculator": {
      "command": "node",
      "args": ["./example-mcp-server/index.js"],
      "transport": "stdio"
    }
  },
  "server": {
    "port": 3000
  },
  "scheduler": {
    "enabled": true,
    "timezone": "Asia/Shanghai",
    "tasks": {
      "nightlyConsolidate": {
        "enabled": true,
        "cron": "0 3 * * *"
      },
      "cleanupOldLogs": {
        "enabled": true,
        "cron": "0 4 * * *",
        "retentionDays": 30
      },
      "cleanupOldCommitments": {
        "enabled": true,
        "cron": "30 4 * * *",
        "retentionDays": 30
      }
    }
  },
  "builtinTools": {
    "mode": "whitelist",
    "enabled": [
      "tool_search",
      "read_file",
      "list_directory",
      "fetch_url",
      "skill_list",
      "skill_create",
      "skill_update",
      "skill_delete"
    ]
  },
  "cognitive": {
    "autoLevel": "semi-auto",
    "dream": {
      "threshold": 5,
      "minScore": 3
    },
    "learn": {
      "minToolCalls": 3
    },
    "retrieval": {
      "topK": 8
    }
  },
  "a2a": {
    "enabled": true,
    "centerUrl": "http://a2a-center:8888",
    "agentUrl": "http://localhost:3000",
    "agentCard": {
      "name": "MCP Conversation Agent",
      "description": "An AI agent powered by MCP Conversation Engine. Receives A2A tasks, processes them using LLM reasoning and available tools, and pushes results back.",
      "skills": [
        {
          "id": "general-chat",
          "name": "General Chat",
          "description": "Process general conversational tasks via LLM",
          "tags": ["chat", "nlp", "conversation"]
        },
        {
          "id": "tool-use",
          "name": "Tool Use",
          "description": "Use available MCP tools to accomplish tasks",
          "tags": ["tools", "automation", "mcp"]
        }
      ]
    }
  }
}
